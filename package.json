{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'); const p='public'; if(!fs.existsSync(p))fs.mkdirSync(p,{recursive:true}); fs.copyFileSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs',p+'/pdf.worker.min.mjs')\" && node -e \"const fs=require('fs'),path=require('path'),src='scripts/pre-commit-check-secrets.sh',hookDir=path.join('.git','hooks'),dst=path.join(hookDir,'pre-commit'); if(fs.existsSync(src)&&fs.existsSync(hookDir)&&!fs.existsSync(dst)){fs.copyFileSync(src,dst); try{fs.chmodSync(dst,'755')}catch(e){}}\"",
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:smoke": "npx playwright test",
    "typecheck": "node scripts/typecheck.mjs",
    "clean": "next clean",
    "check:secrets": "bash scripts/pre-commit-check-secrets.sh",
    "validate:supabase-functions": "node scripts/validate-supabase-functions.mjs",
    "check:stripe-config": "node scripts/check-stripe-config.mjs",
    "test:payment-mocks": "jest --runInBand __tests__/security/payment.security.test.ts",
    "check:rate-limiting": "node scripts/check-rate-limiting.mjs",
    "deploy:prod": "node scripts/deploy-prod.mjs",
    "deploy:supabase-functions": "node scripts/deploy-supabase-functions.mjs",
    "validate:health-check": "node scripts/validate-health-check.mjs",
    "check:payment-system": "node scripts/check-payment-system.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "appwrite": "^24.1.1",
    "autoprefixer": "^10.4.21",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.5.14",
    "node-appwrite": "^23.1.0",
    "pdfjs-dist": "^5.5.207",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "stripe": "^20.4.1",
    "supabase": "^2.77.0",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "eslint-plugin-security": "^3.0.1",
    "firebase-tools": "^15.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "4.1.11",
    "ts-jest": "^29.4.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.1"
  },
  "overrides": {
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13",
    "lodash": "^4.18.0",
    "handlebars": "^4.7.9",
    "brace-expansion": "^2.0.3",
    "picomatch": "^2.3.2",
    "flatted": "^3.4.2",
    "tar": "^7.5.11",
    "@tootallnate/once": "^3.0.1"
  }
}
