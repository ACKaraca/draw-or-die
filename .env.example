# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=https://drawordie.ackaraca.me
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=draw-or-die

# Appwrite server (required for API routes)
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=draw-or-die
APPWRITE_API_KEY=your-appwrite-server-api-key

# Optional: specific provider for edu verification emails
# If omitted, Appwrite Messaging first configured email provider is used.
APPWRITE_EDU_EMAIL_PROVIDER_ID=your-email-provider-id

# AI Configuration (ai-generate Edge Function - Supabase secrets, NOT committed here)
# AI_API_KEY=your-api-key
# AI_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_MODEL=google/gemini-3.1-flash-lite-preview

# CORS: comma-separated list of allowed origins for the ai-generate Edge Function
# Set this as a Supabase secret: supabase secrets set ALLOWED_ORIGINS=https://drawordie.ackaraca.me
# ALLOWED_ORIGINS=https://drawordie.ackaraca.me,https://www.drawordie.ackaraca.me

